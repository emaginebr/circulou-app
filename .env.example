# Variáveis de ambiente do Circulou (Vite)
# Princípio VI da constituição: prefixo VITE_ é obrigatório.
# Cópia local: cp .env.example .env.local

# URL base da API do Lofn (REST e GraphQL).
# A REST é exposta em endpoints como POST /product/search, POST /shopcart/insert, etc.
# O GraphQL público fica sempre em {VITE_API_URL}/graphql (queries: stores, storeBySlug,
# featuredProducts, categories, products) — não há variável separada.
VITE_API_URL=https://lofn.dev.example.com

# URL base da API REST do NAuth (login, register, getMe, etc.)
VITE_NAUTH_URL=https://nauth.dev.example.com

# Base path do React Router 6 (deixe em branco se servido na raiz)
VITE_SITE_BASENAME=
